{
  // Static-assets-only Worker for the pyssg documentation site.
  // `pyssg build` writes the site to ./public, which Cloudflare serves directly;
  // no Worker script (`main`) is needed for a pure static deployment.
  "name": "pyssg",
  "compatibility_date": "2025-05-01",
  "assets": {
    "directory": "./public"
  }
}
